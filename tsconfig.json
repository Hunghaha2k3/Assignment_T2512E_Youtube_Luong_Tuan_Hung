{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["DOM", "ES2017"],
    "module": "ESNext",
    "jsx": "react-jsx",
    "moduleResolution": "Node",
    "types": ["react", "react-dom"],
    "esModuleInterop": true,
//    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "allowJs": true
  }
}

